# Google Calendar API Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3006/api/auth/google/callback

# Calendar IDs por departamento (opcional - usar 'primary' por defecto)
CALENDAR_ADMIN_ID=primary
CALENDAR_ACA_ID=primary
CALENDAR_ATIC_ID=primary
CALENDAR_RRHH_ID=primary
CALENDAR_CEO_ID=primary
CALENDAR_ADE_ID=primary
CALENDAR_MYD_ID=primary
CALENDAR_PROPIETARIO_ID=primary

# Existing environment variables...
NODE_ENV=develop
SECRET=your_secret_here

# Database configuration
POSTGRES_DEV_USER=
POSTGRES_DEV_PASSWORD=
POSTGRES_DEV_HOST=
POSTGRES_DEV_PORT=
POSTGRES_DEV_DB=