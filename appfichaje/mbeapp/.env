# Archivo .env para uso local/servidor
#  - Rellenar los valores entre <> antes de arrancar la aplicación
#  - NO subir este archivo a un repositorio público
#  - Reiniciar la app después de editar (pm2/systemd)

### SMTP / Notificaciones (reemplaza <...> por tus valores reales)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
# 'true' para TLS/SSL (puerto 465). 'false' para STARTTLS (puerto 587).
SMTP_SECURE=true
SMTP_USER=atic1@mbe.madrid
# Pon aquí tu contraseña de aplicación (App Password) — NO tu contraseña normal
SMTP_PASS=veuu nfzr llrp umud

# Opcionales: desde / reply-to / destinatario por defecto
LATE_ALERT_FROM="no-reply@mbe.madrid"
LATE_ALERT_REPLY_TO="rrhh1@mbe.madrid"
# Correo del responsable por defecto (si el cliente no manda responsibleEmail)
LATE_ALERT_FALLBACK_RECIPIENT="rrhh1@mbe.madrid"
LATE_ALERT_FALLBACK_NAME="Responsable RRHH"

# Límite semanal por defecto (si no lo envía el cliente)
LATE_ALERT_WEEKLY_LIMIT=3

# DEBUG: secreto para rutas de administración de prueba
# Rellena con un valor fuerte (ej: 32 chars alfanumérico). Si lo dejas vacío, la ruta debug rechazará peticiones.
DEBUG_ADMIN_SECRET=8REM8rC2QSGbZ94DbSxtwjRPCwyFQbP6

# NOTA: Mantén este archivo fuera de control de versiones (añade a .gitignore si hace falta)
PORT=3005
DEVPORT=3005

# properties TCP
TCP_PROD=http://185.252.233.57:3005
TCP_DEV=http://185.252.233.57:3005

# properties API REST
API_REST_PROD=http://185.252.233.57:3006
API_REST_DEV=http://185.252.233.57:3006

# API endpoint for check-in
API_ENDPOINT=http://185.252.233.57:3006

# Client Next.js URL
CLIENT_URL=http://185.252.233.57:6969
