<div class="container">
    <h2 class="mb-4">Primer acceso de usuarios</h2>

    <div class="d-flex justify-content-end mb-3">
        <a href="/admin/first-login/daily" class="btn btn-outline-primary">Ver verificación diaria</a>
    </div>

    {{{warning}}}

    {{#if existRegistros}}
        <div class="table-responsive shadow-sm">
            <table class="table table-striped table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Usuario</th>
                        <th>Correo</th>
                        <th>Departamento</th>
                        <th>Estado</th>
                        <th>Fecha primer acceso</th>
                        <th>IP</th>
                        <th>Dispositivo</th>
                        <th>Detalles</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each registros}}
                        <tr>
                            <td>{{index}}</td>
                            <td>
                                <strong>{{username}}</strong><br>
                                <small>{{nombre_completo}}</small>
                            </td>
                            <td>{{email}}</td>
                            <td>{{department}}</td>
                            <td>
                                {{#if estado}}
                                    <span class="badge bg-success">Activo</span>
                                {{else}}
                                    <span class="badge bg-secondary">Inactivo</span>
                                {{/if}}
                            </td>
                            <td>{{first_login_at}}</td>
                            <td>{{ip}}</td>
                            <td>{{user_agent}}</td>
                            <td>
                                <details>
                                    <summary>Ver JSON</summary>
                                    <pre class="mt-2 small bg-light p-2 border">{{metadata_json}}</pre>
                                </details>
                            </td>
                        </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    {{else}}
        <div class="alert alert-info" role="alert">
            No se han registrado primeros accesos todavía.
        </div>
    {{/if}}
</div>
