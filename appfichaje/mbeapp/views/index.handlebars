<link rel="shortcut icon" href="https://ibb.co/zRHrrWf">

<style>
    button {
        color: #F18420 !important;
    }

    h4 {
        color: #1387C9 !important;
        font-weight: bold;
    }

    h6 {
        color: #fa0202;
        font-weight: bold;
    }

    #logout {
        color: white !important;
    }

    form {
        text-align: center;
    }

    @media screen and (max-width: 420px) {
        svg {
            width: 30%;
            height: 30%;
        }

        img {
            width: 80%;
        }
    }

    @media screen and (max-width: 620px) {
        div.menu-main {
            margin-bottom: 15px;
        }
    }

    .menubtn:hover {
        transform: scale(1.2);
        transition: .6s;
    }

    .menubtn:not(:hover) {
        transform: scale(1);
        transition: .6s;
    }

    .success-message {
        text-align: center;
        font-size: 1.5rem;
        font-weight: bold;
        color: #28a745;
        margin-top: 20px;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        animation: fadeIn 1s ease-in-out;
    }

    .fichaje-message {
        text-align: center;
        font-size: 1.2rem;
        font-weight: bold;
        margin-top: 15px;
        padding: 10px;
        border-radius: 8px;
        animation: fadeIn 1s ease-in-out;
    }

    .fichaje-success {
        color: #155724;
        background-color: #d4edda;
        border: 1px solid #c3e6cb;
    }

    .fichaje-error {
        color: #721c24;
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
    }

    .fichaje-icon {
        font-size: 1.3rem;
        margin-right: 8px;
    }

    .success-icon {
        font-size: 1.8rem;
        animation: pop 0.5s ease;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes pop {
        0% {
            transform: scale(0);
        }
        60% {
            transform: scale(1.3);
        }
        100% {
            transform: scale(1);
        }
    }
</style>

<div class="m-2">
    <img src="https://mbe.madrid/wp-content/uploads/2025/05/MBE_horizontal-logo.png" width="50%" class="mx-auto d-block" id="icon" alt="MyCityHome" />

    <div class="container" style="display: flex; gap: 1rem;">
        <div class="row d-flex justify-content-around">
        </div>
    </div>

    <!-- Mensaje de éxito -->
    <div class="success-message">
        <span class="success-icon">✅</span>
        ¡Inicio de sesión exitoso!
    </div>

    <!-- Mensaje de estado del fichaje -->
    <div id="fichajeStatus" class="fichaje-message" style="display: none;">
        <span id="fichajeIcon" class="fichaje-icon"></span>
        <span id="fichajeText"></span>
    </div>

    <div class="text-center mt-4">
        <form method="post" action="/logout">
            <button type="submit" id="logout" class="btn btn-danger">
                <h5>LogOut</h5>
            </button>
        </form>
    </div>

    <div class="alert alert-warning text-center" role="alert" style="display: flex; align-items: center; justify-content: center; padding: 1rem; max-width: 150px;">
        <h6 style="margin: 0;">Recuerda pulsar LOGOUT.</h6>
    </div>

</div>

<script>
    // Check for fichaje result in sessionStorage
    document.addEventListener('DOMContentLoaded', function() {
        const fichajeResult = sessionStorage.getItem('fichajeResult');
        if (fichajeResult) {
            try {
                const result = JSON.parse(fichajeResult);
                const statusDiv = document.getElementById('fichajeStatus');
                const iconSpan = document.getElementById('fichajeIcon');
                const textSpan = document.getElementById('fichajeText');
                
                if (result.success) {
                    statusDiv.className = 'fichaje-message fichaje-success';
                    iconSpan.textContent = '✅';
                    textSpan.textContent = result.message;
                } else {
                    statusDiv.className = 'fichaje-message fichaje-error';
                    iconSpan.textContent = '❌';
                    textSpan.textContent = result.message + (result.error ? ': ' + result.error : '');
                }
                
                // Show additional details if available
                if (result.user || result.timestamp || result.action) {
                    const details = document.createElement('div');
                    details.style.fontSize = '0.9rem';
                    details.style.marginTop = '5px';
                    details.style.opacity = '0.8';
                    
                    let detailText = '';
                    if (result.user) detailText += `Usuario: ${result.user} `;
                    if (result.timestamp) detailText += `Hora: ${result.timestamp} `;
                    if (result.action) detailText += `Tipo: ${result.action.charAt(0).toUpperCase() + result.action.slice(1)}`;
                    
                    details.textContent = detailText.trim();
                    statusDiv.appendChild(details);
                }
                
                statusDiv.style.display = 'block';
                
                // Clear the result after showing it
                sessionStorage.removeItem('fichajeResult');
                
                // Auto-hide after 10 seconds
                setTimeout(() => {
                    statusDiv.style.opacity = '0';
                    setTimeout(() => {
                        statusDiv.style.display = 'none';
                    }, 500);
                }, 10000);
                
            } catch (error) {
                console.error('Error parsing fichaje result:', error);
            }
        }
    });
</script>