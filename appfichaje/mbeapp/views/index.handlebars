<link rel="shortcut icon" href="/img/ico/MBE_symbol.png">

<style>
    button {
        color: #F18420 !important;
    }

    h4 {
        color: #1387C9 !important;
        font-weight: bold;
    }

    h6 {
        color: #fa0202;
        font-weight: bold;
    }

    #logout {
        color: white !important;
    }

    form {
        text-align: center;
    }

    @media screen and (max-width: 420px) {
        svg {
            width: 30%;
            height: 30%;
        }

        img {
            width: 80%;
        }
    }

    @media screen and (max-width: 620px) {
        div.menu-main {
            margin-bottom: 15px;
        }
    }

    .menubtn:hover {
        transform: scale(1.2);
        transition: .6s;
    }

    .menubtn:not(:hover) {
        transform: scale(1);
        transition: .6s;
    }

    .success-message {
        text-align: center;
        font-size: 1.5rem;
        font-weight: bold;
        color: #28a745;
        margin-top: 20px;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        animation: fadeIn 1s ease-in-out;
    }

    .fichaje-message {
        text-align: center;
        font-size: 1.2rem;
        font-weight: bold;
        margin-top: 15px;
        padding: 10px;
        border-radius: 8px;
        animation: fadeIn 1s ease-in-out;
    }

    .fichaje-success {
        color: #155724;
        background-color: #d4edda;
        border: 1px solid #c3e6cb;
    }

    .fichaje-error {
        color: #721c24;
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
    }

    .fichaje-icon {
        font-size: 1.3rem;
        margin-right: 8px;
    }

    .success-icon {
        font-size: 1.8rem;
        animation: pop 0.5s ease;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes pop {
        0% {
            transform: scale(0);
        }
        60% {
            transform: scale(1.3);
        }
        100% {
            transform: scale(1);
        }
    }
</style>

<div class="m-2">
    <img src="https://mbe.madrid/wp-content/uploads/2025/05/MBE_horizontal-logo.png" width="50%" class="mx-auto d-block" id="icon" alt="MBE" />

    <div class="container" style="display: flex; gap: 1rem;">
        <div class="row d-flex justify-content-around">
        </div>
    </div>

    <!-- Mensaje de éxito -->
    <div class="success-message">
        <span class="success-icon">✅</span>
        ¡Inicio de sesión exitoso!
    </div>

    <!-- Mensaje de estado del fichaje -->
    <div id="fichajeStatus" class="fichaje-message" style="display: none;">
        <span id="fichajeIcon" class="fichaje-icon"></span>
        <span id="fichajeText"></span>
    </div>

    <div class="text-center mt-4">
        <form method="post" action="/logout">
            <button type="submit" id="logout" class="btn btn-danger">
                <h5>LogOut</h5>
            </button>
        </form>
    </div>

    <div style="display: flex; justify-content: center; margin-top: 20px;">
        <div class="alert alert-warning text-center" role="alert" style="display: flex; align-items: center; justify-content: center; padding: 1rem; max-width: 150px; margin: 0;">
            <h6 style="margin: 0;">Recuerda pulsar LOGOUT.</h6>
        </div>
    </div>

</div>

<!-- Modal aviso llegada tarde -->
<div class="modal fade" id="lateAlertModal" tabindex="-1" aria-labelledby="lateAlertLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning bg-opacity-25">
                <h5 class="modal-title" id="lateAlertLabel">Aviso de llegada tarde</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p id="lateMinutesMessage" class="mb-2 fw-bold text-danger"></p>
                <p id="lateWeeklyCounter" class="mb-2 text-muted"></p>
                <div id="lateNotifyWrapper" class="alert alert-warning d-none" role="alert">
                    Se le notificará a su responsable (límite 3).
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn" style="background-color: #fff0c2; color: #000;" data-bs-dismiss="modal">Entendido</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Mensaje mostrado tras el cierre de sesión. Personalízalo aquí.
    const LOGOUT_NOTICE_MESSAGE = '¡Recuerda estar pendiente por si te llega un examen!';

    const LateSummaryHelper = (() => {
        const LATE_LIMIT = 3;

        const getWeekKey = (dateStr) => {
            if (!dateStr || typeof dateStr !== 'string') {
                const today = new Date();
                return getWeekKey(today.toISOString().split('T')[0]);
            }
            const [year, month, day] = dateStr.split('-').map(Number);
            if ([year, month, day].some(Number.isNaN)) {
                const today = new Date();
                return getWeekKey(today.toISOString().split('T')[0]);
            }
            const dt = new Date(Date.UTC(year, month - 1, day));
            const dayNum = dt.getUTCDay() || 7;
            dt.setUTCDate(dt.getUTCDate() + 4 - dayNum);
            const yearStart = new Date(Date.UTC(dt.getUTCFullYear(), 0, 1));
            const weekNo = Math.ceil((((dt - yearStart) / 86400000) + 1) / 7);
            return `${dt.getUTCFullYear()}-W${weekNo.toString().padStart(2, '0')}`;
        };

        const readStored = (userId, targetWeekKey) => {
            if (!userId) return null;
            let stored;
            try {
                stored = JSON.parse(localStorage.getItem(`fichaje_late_counter_${userId}`) || '{}');
            } catch (_) {
                stored = null;
            }
            if (!stored || stored.weekKey !== targetWeekKey) return null;

            const limit = typeof stored.limit === 'number' ? stored.limit : LATE_LIMIT;
            let totalCount = 0;

            if (Array.isArray(stored.details)) {
                totalCount = stored.details.length;
            } else if (typeof stored.count === 'number') {
                totalCount = stored.count;
            } else {
                totalCount = Object.values(stored.days || {}).reduce(
                    (acc, info) => acc + (info.occurrences || 1),
                    0
                );
            }

            const remainingRaw = typeof stored.remaining === 'number'
                ? stored.remaining
                : (limit - totalCount);
            const remaining = Math.max(remainingRaw, 0);

            const shouldNotify = typeof stored.shouldNotify === 'boolean'
                ? stored.shouldNotify
                : totalCount >= limit;

            return {
                weekKey: stored.weekKey,
                count: totalCount,
                limit,
                remaining,
                shouldNotify,
                days: stored.details || stored.days || {}
            };
        };

        return { getWeekKey, readStored };
    })();

    // Check for fichaje result in sessionStorage
    document.addEventListener('DOMContentLoaded', function() {
        const logoutForm = document.querySelector('form[action="/logout"]');
        if (logoutForm) {
            logoutForm.addEventListener('submit', function() {
                sessionStorage.setItem('logoutNotice', JSON.stringify({ message: LOGOUT_NOTICE_MESSAGE }));
            });
        }

        const fichajeResult = sessionStorage.getItem('fichajeResult');
        if (fichajeResult) {
            try {
                const result = JSON.parse(fichajeResult);
                const statusDiv = document.getElementById('fichajeStatus');
                const iconSpan = document.getElementById('fichajeIcon');
                const textSpan = document.getElementById('fichajeText');
                
                if (result.success) {
                    statusDiv.className = 'fichaje-message fichaje-success';
                    iconSpan.textContent = '✅';
                    if (result.lateInfo && result.lateInfo.isLate) {
                        const minutes = Number(result.lateInfo.lateMinutes || 0);
                        const minutesLabel = minutes === 1 ? 'minuto' : 'minutos';
                        textSpan.textContent = `${result.message}. Llegaste tarde ${minutes} ${minutesLabel} respecto a las 09:04.`;
                    } else {
                        textSpan.textContent = result.message;
                    }
                } else {
                    statusDiv.className = 'fichaje-message fichaje-error';
                    iconSpan.textContent = '❌';
                    textSpan.textContent = result.message + (result.error ? ': ' + result.error : '');
                }
                
                // Show additional details if available
                if (result.user || result.timestamp || result.action) {
                    const details = document.createElement('div');
                    details.style.fontSize = '0.9rem';
                    details.style.marginTop = '5px';
                    details.style.opacity = '0.8';
                    
                    let detailText = '';
                    if (result.user) detailText += `Usuario: ${result.user} `;
                    if (result.timestamp) detailText += `Hora: ${result.timestamp} `;
                    if (result.action) detailText += `Tipo: ${result.action.charAt(0).toUpperCase() + result.action.slice(1)}`;
                    
                    details.textContent = detailText.trim();
                    statusDiv.appendChild(details);
                }
                
                statusDiv.style.display = 'block';

                if (result.lateInfo && result.lateInfo.isLate) {
                    const minutes = Number(result.lateInfo.lateMinutes || 0);
                    const minutesLabel = minutes === 1 ? 'minuto' : 'minutos';
                    const lateModalEl = document.getElementById('lateAlertModal');
                    const lateMessageEl = document.getElementById('lateMinutesMessage');
                    const lateCounterEl = document.getElementById('lateWeeklyCounter');
                    const lateNotifyEl = document.getElementById('lateNotifyWrapper');

                    if (lateModalEl && lateMessageEl && lateCounterEl && lateNotifyEl) {
                        lateMessageEl.textContent = `Has llegado tarde ${minutes} ${minutesLabel}. Debías fichar antes de las 09:04.`;

                        const weekKey = LateSummaryHelper.getWeekKey(result.lateInfo.fecha);
                        let summary = result.lateSummary || LateSummaryHelper.readStored(result.user, weekKey);

                        if (summary) {
                            const countLabel = summary.count === 1 ? 'día' : 'días';
                            const extraDays = Math.max(summary.count - summary.limit, 0);
                            let counterMessage = `Retrasos esta semana: ${summary.count} ${countLabel} de ${summary.limit}.`;

                            if (extraDays > 0) {
                                const extraLabel = extraDays === 1 ? 'día' : 'días';
                                counterMessage += ` Has superado el límite por ${extraDays} ${extraLabel}.`;
                            } else if (summary.remaining > 0) {
                                const remainingLabel = summary.remaining === 1 ? 'día' : 'días';
                                counterMessage += ` Te quedan ${summary.remaining} ${remainingLabel} antes de llegar al límite.`;
                            }

                            lateCounterEl.textContent = counterMessage;

                            if (summary.shouldNotify) {
                                lateNotifyEl.classList.remove('d-none');
                            } else {
                                lateNotifyEl.classList.add('d-none');
                            }
                        } else {
                            lateCounterEl.textContent = '';
                            lateNotifyEl.classList.add('d-none');
                        }

                        const modalInstance = new bootstrap.Modal(lateModalEl);
                        modalInstance.show();
                    }
                }
                
                // Clear the result after showing it
                sessionStorage.removeItem('fichajeResult');
                
                // Auto-hide after 10 seconds
                setTimeout(() => {
                    statusDiv.style.opacity = '0';
                    setTimeout(() => {
                        statusDiv.style.display = 'none';
                    }, 500);
                }, 10000);
                
            } catch (error) {
                console.error('Error parsing fichaje result:', error);
            }
        }
    });
</script>