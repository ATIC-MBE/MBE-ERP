<div class="container">
    <h2 class="mb-4">Verificación diaria de primeros accesos</h2>

    <form method="get" class="row g-3 align-items-center mb-4">
        <div class="col-auto">
            <label for="date" class="col-form-label fw-bold">Selecciona día:</label>
        </div>
        <div class="col-auto">
            <input
                type="date"
                id="date"
                name="date"
                class="form-control"
                value="{{appliedDate}}"
                max="{{todayIso}}"
            />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Consultar</button>
        </div>
        <div class="col-auto">
            <a href="/admin/first-login" class="btn btn-outline-secondary">Ver histórico completo</a>
        </div>
    </form>

    {{{warning}}}

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <span class="fw-bold">Fecha consultada:</span>
            <span>{{appliedDateHuman}}</span>
        </div>
        <div>
            <span class="badge bg-dark">{{total}} registros</span>
        </div>
    </div>

    {{#if existRegistros}}
        <div class="table-responsive shadow-sm">
            <table class="table table-striped table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Usuario</th>
                        <th>Correo</th>
                        <th>Departamento</th>
                        <th>Estado</th>
                        <th>Hora primer acceso</th>
                        <th>IP</th>
                        <th>Dispositivo</th>
                        <th>Metadatos</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each registros}}
                        <tr>
                            <td>{{index}}</td>
                            <td>
                                <strong>{{username}}</strong><br>
                                <small>{{nombre_completo}}</small>
                            </td>
                            <td>{{email}}</td>
                            <td>{{department}}</td>
                            <td>
                                {{#if estado}}
                                    <span class="badge bg-success">Activo</span>
                                {{else}}
                                    <span class="badge bg-secondary">Inactivo</span>
                                {{/if}}
                            </td>
                            <td>
                                <span class="fw-bold">{{hora}}</span><br>
                                <small class="text-muted">{{fechaCompleta}}</small>
                            </td>
                            <td>{{ip}}</td>
                            <td>{{user_agent}}</td>
                            <td>
                                <details>
                                    <summary>Ver JSON</summary>
                                    <pre class="mt-2 small bg-light p-2 border">{{metadata_json}}</pre>
                                </details>
                            </td>
                        </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    {{else}}
        <div class="alert alert-info" role="alert">
            No se han registrado primeros accesos en la fecha seleccionada.
        </div>
    {{/if}}
</div>
