# Configuración para Google Sheets API
# Copiar este archivo como .env.local y completar con los valores reales

# API Key de Google Sheets (obtenida desde Google Cloud Console)
GOOGLE_SHEETS_API_KEY=tu_api_key_aqui

# ID del documento de Google Sheets (se obtiene de la URL del documento)
# Ejemplo: https://docs.google.com/spreadsheets/d/1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms/edit
# El ID sería: 1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms
GOOGLE_SHEETS_ID=tu_spreadsheet_id_aqui

# Configuración API endpoints
API_END_POINT_PROD=http://localhost:3006
API_END_POINT_DEV=http://localhost:3006